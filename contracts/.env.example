# Foundry deploy config. The contracts are EVM-portable — the same Deploy.s.sol
# deploys to Arc, Base Sepolia or Base mainnet; only these env values change.

# Broadcasting key (owner of Factory + Resolver). NEVER commit the real key.
DEPLOYER_PK=0x...

# Backend address used as verifier (registerCreator) + oracle (resolve).
BACKEND_ADDR=0x199D2956A804d48804a9482240D03Dab0495F578

# ── Collateral (USDC) per network ──
# Arc testnet:     0x3600000000000000000000000000000000000000
# Base Sepolia:    0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Base mainnet:    0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# "1" to seed demo markets (deployer must hold USDC). Leave empty for prod.
SEED=

# ── Chainlink feed allowlist (security) ──
# Canonical AggregatorV3 addresses on the SETTLEMENT chain (docs.chain.link). The deploy
# script allowlists them in the Resolver; setPriceFeed only accepts allowlisted feeds.
# These MUST match the backend's ONCHAIN_FEED_* env values.
FEED_ETH=
FEED_BTC=
FEED_LINK=

# ── RPC per network (pass on the forge command line) ──
# Base Sepolia:  https://sepolia.base.org
# Base mainnet:  https://mainnet.base.org
# Arc testnet:   https://rpc.testnet.arc.network
#
# Deploy:
#   forge script script/Deploy.s.sol --rpc-url https://sepolia.base.org --broadcast --verify
#
# After deploy, copy FACTORY/RESOLVER addresses + the deploy block into
# contracts/deployments/base-sepolia.json (or base-mainnet.json), then run the
# backend with NETWORK=base-sepolia.
