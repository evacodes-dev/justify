# Deploy config for the product stack (script/DeployCtf.s.sol): the audited Gnosis
# CTF/FPMM contracts (vendored verbatim under vendor/) + our thin layer
# (MarketRegistry, CtfResolver, OptimisticSettler, CREResolverModule).

# Broadcasting key (owner of registry/resolver/settler). NEVER commit the real key.
DEPLOYER_PK=0x...

# Backend address: World ID verifier + AI proposer + break-glass oracle.
BACKEND_ADDR=0x199D2956A804d48804a9482240D03Dab0495F578

# ── Collateral (USDC) per network ──
# Base Sepolia:    0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Base mainnet:    0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# UMA Optimistic Oracle V3 on the settlement chain (docs.uma.xyz -> Deployments).
# USDC must be an OOv3-whitelisted bond currency on that chain.
OOV3_ADDRESS=

# Audited Gnosis stack: leave empty to deploy the VENDORED bytecode verbatim
# (build first: cd vendor && forge build), or point at existing canonical instances.
CTF_ADDRESS=
FPMM_FACTORY=

# ── Chainlink feed allowlist (security) ──
# Canonical AggregatorV3 addresses on the SETTLEMENT chain (docs.chain.link). The deploy
# script allowlists them in the CtfResolver; setPriceFeed only accepts allowlisted feeds.
# MUST match the backend's ONCHAIN_FEED_* env values.
FEED_ETH=
FEED_BTC=
FEED_LINK=

# Optimistic settlement windows (seconds)
CHALLENGE_WINDOW=7200
DISPUTE_LIVENESS=7200

# Chainlink CRE forwarder (once the DON workflow is deployed; optional)
CRE_FORWARDER=

# Deploy:
#   cd vendor && forge build && cd ..
#   forge script script/DeployCtf.s.sol --rpc-url https://sepolia.base.org --broadcast --verify
# Then copy the printed addresses into contracts/deployments/base-sepolia.json
# (MarketRegistry / Resolver=CtfResolver / ConditionalTokens / FpmmFactory /
#  OptimisticSettler / CREModule) + the deploy block, and run the backend with
# NETWORK=base-sepolia.
