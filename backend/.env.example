# Justify backend — copy to .env and fill. Never commit .env.
PORT=8787

# Network: which contracts/deployments/<NETWORK>.json to load.
# arc-testnet (default) | base-sepolia | base-mainnet
NETWORK=base-sepolia

# RPC override (else the deployment file's rpc is used). RPC_URL preferred; ARC_RPC kept for back-compat.
# Base Sepolia: https://sepolia.base.org · Base mainnet: https://mainnet.base.org
RPC_URL=https://sepolia.base.org
ARC_RPC=https://rpc.testnet.arc.network

# Backend signer — acts as verifier (registerCreator), oracle (resolve) and faucet (gas dotation).
# Must equal the `backend` address in contracts/deployments/arc-testnet.json. KMS in prod.
BACKEND_PK=0x...

# On-chain Chainlink Data Feeds (settlement chain) for trustless price resolution.
# Set once verified at docs.chain.link for the active NETWORK. If unset, resolution
# falls back to the off-chain read. FEED_MAX_STALE_SEC bounds price freshness.
ONCHAIN_FEED_ETH=
ONCHAIN_FEED_BTC=
ONCHAIN_FEED_LINK=
FEED_MAX_STALE_SEC=3600

# Gas dotation (BE11): native top-up so embedded wallets can pay gas. On Base native=ETH
# (tiny amounts); on Arc native=USDC. Defaults adapt to NETWORK; override here if needed.
GAS_DRIP_THRESHOLD=0.0002
GAS_DRIP_AMOUNT=0.0005

# AI (agent decisions = Haiku, resolution = Sonnet)
ANTHROPIC_API_KEY=

# World ID 4.0 (onboarding proof-of-human)
WORLD_APP_ID=app_...
WORLD_RP_ID=rp_...

# Blink deposit signer (ECDSA P-256). PEM file path + merchant id.
BLINK_MERCHANT_ID=
BLINK_PRIVATE_KEY_PEM=./blink-private.pem

# Agent / anti-sybil
APPROVAL_THRESHOLD_USDC=5
MAX_AGENTS_PER_HUMAN=3
FREE_TRIAL_BETS_PER_HUMAN=10

# BE12 — durable storage. If set, every store write is mirrored to Postgres (JSONB blob
# per table) and the cache is hydrated from it at boot. Unset = file-only (dev/demo).
DATABASE_URL=

# World ID RP signing (server-only) + dev bypass toggle
RP_SIGNING_KEY=
WORLD_ACTION=create-market
ALLOW_DEV_VERIFY=true
