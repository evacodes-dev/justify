# Justify backend — copy to .env and fill. Never commit .env.
PORT=8787

# Arc testnet
ARC_RPC=https://rpc.testnet.arc.network

# Backend signer — acts as verifier (registerCreator), oracle (resolve) and faucet (gas dotation).
# Must equal the `backend` address in contracts/deployments/arc-testnet.json. KMS in prod.
BACKEND_PK=0x...

# AI (agent decisions = Haiku, resolution = Sonnet)
ANTHROPIC_API_KEY=

# World ID 4.0 (onboarding proof-of-human)
WORLD_APP_ID=app_...
WORLD_RP_ID=rp_...

# Blink deposit signer (ECDSA P-256). PEM file path + merchant id.
BLINK_MERCHANT_ID=
BLINK_PRIVATE_KEY_PEM=./blink-private.pem

# Agent / anti-sybil
APPROVAL_THRESHOLD_USDC=5
MAX_AGENTS_PER_HUMAN=3
FREE_TRIAL_BETS_PER_HUMAN=10

# World ID RP signing (server-only) + dev bypass toggle
RP_SIGNING_KEY=
WORLD_ACTION=create-market
ALLOW_DEV_VERIFY=true
